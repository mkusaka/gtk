{
  "name": "gtk",
  "version": "0.0.1",
  "description": "BYO-credentials Google Tasks CLI",
  "type": "module",
  "bin": {
    "gtk": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "skills"
  ],
  "engines": {
    "node": ">=24.13.1"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "compile:binary": "pnpm build && deno compile --no-lock -A --node-modules-dir=auto --output dist/gtk dist/index.js",
    "dev": "tsx src/index.ts",
    "format": "oxfmt --write src test vitest.config.ts",
    "format:check": "oxfmt --check src test vitest.config.ts",
    "lint": "pnpm run lint:types && pnpm run lint:oxlint",
    "lint:oxlint": "oxlint . --deny-warnings",
    "lint:types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "google-auth-library": "^10.4.1",
    "googleapis": "^171.4.0",
    "open": "^10.2.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
