{
  "name": "gtk",
  "version": "0.1.0",
  "description": "BYO-credentials Google Tasks CLI",
  "type": "module",
  "bin": {
    "gtk": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "skills"
  ],
  "engines": {
    "node": ">=24.13.1"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
